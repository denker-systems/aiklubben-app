{
  "expo": {
    "name": "AI Klubben",
    "slug": "aiklubben-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8B5CF6",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AI Klubben uses your location to show locally relevant AI news and events.",
          "locationWhenInUsePermission": "AI Klubben uses your location to show locally relevant AI news and events."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nu.aiklubben.app",
      "buildNumber": "8",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "nu.aiklubben.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "c44a138e-9537-4cd3-897b-5dd3c2fe4bf4"
      }
    },
    "owner": "denkersystems",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c44a138e-9537-4cd3-897b-5dd3c2fe4bf4"
    }
  }
}
